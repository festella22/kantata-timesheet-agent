# Kantata (Mavenlink) API credentials.
# install.ps1 copies this to ~/.claude/kantata-timesheet/kantata.env — fill in THERE.
# The filled copy lives outside the repo and must never be committed or shared.
#
# PREFERRED: a personal API token. In Kantata go to
# Settings -> API (or your profile -> API tokens) and generate a token.
KANTATA_API_TOKEN=REPLACE_WITH_YOUR_API_TOKEN

# Base URL for the API (leave as-is unless your workspace is EU-hosted:
# https://api.eu.mavenlink.com).
KANTATA_BASE_URL=https://api.mavenlink.com

# FALLBACK (only if your workspace uses OAuth apps instead of API tokens):
# KANTATA_CLIENT_ID=
# KANTATA_CLIENT_SECRET=
