# Kantata Auto-Timesheet Agent — Credential Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Kantata (Mavenlink) — obtain from your workspace admin → Settings → API
KANTATA_CLIENT_ID=your_kantata_client_id
KANTATA_CLIENT_SECRET=your_kantata_client_secret
KANTATA_WORKSPACE_ID=your_workspace_subdomain   # e.g. pipartners (not the full URL)

# Microsoft Azure AD app — Azure Portal → App registrations → your app
GRAPH_CLIENT_ID=your_azure_app_client_id
GRAPH_CLIENT_SECRET=your_azure_app_client_secret
GRAPH_TENANT_ID=your_azure_tenant_id

# Microsoft Teams incoming webhook URL (optional — used for digest delivery)
# Create via: Teams channel → ... → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Agent behaviour (optional overrides)
DRY_RUN=false                    # set to true to skip Kantata writes and Teams messages
DIGEST_HOUR=8                    # hour (UTC) to send weekly digest (default: 8)
APPROVAL_TIMEOUT_HOURS=24        # hours to wait for approval before auto-hold (default: 24)
MIN_EVENT_DURATION_MINUTES=15    # skip events shorter than this (default: 15)
